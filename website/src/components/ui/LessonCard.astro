---
export interface Props {
  number: number;
  title: string;
  tagline: string;
  subjects: string;     // e.g. "Probability Theory · Python"
  href: string;
  narrativeHook: string; // one-line historical hook
  codeHref: string;     // GitHub directory URL
}

const { number, title, tagline, subjects, href, narrativeHook, codeHref } = Astro.props;
const paddedNum = String(number).padStart(2, "0");
---

<div class="group border border-ivory-dim/15 rounded-xl p-8 hover:border-amber/40 transition-all duration-300 hover:bg-amber/[0.04] relative overflow-hidden">

  <!-- Large dim number background -->
  <span class="absolute top-4 right-6 font-serif font-bold text-8xl text-ivory/[0.06] select-none leading-none group-hover:text-amber/[0.10] transition-colors">
    {paddedNum}
  </span>

  <div class="relative">
    <p class="font-mono text-xs text-amber/80 tracking-widest mb-4 uppercase">
      Lesson {paddedNum} &nbsp;&middot;&nbsp; {subjects}
    </p>

    <h2 class="font-serif text-3xl font-semibold text-ivory mb-2 group-hover:text-amber transition-colors">
      {title}
    </h2>

    <p class="text-ivory/70 text-base italic mb-5">{tagline}</p>

    <p class="text-ivory/80 text-base leading-relaxed mb-7">{narrativeHook}</p>

    <div class="flex items-center gap-6">
      <a href={href}
         class="flex items-center gap-2 text-amber/80 hover:text-amber transition-colors">
        <span class="font-sans text-sm tracking-widest uppercase">Read lesson</span>
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
      <a href={codeHref}
         target="_blank" rel="noopener noreferrer"
         class="flex items-center gap-2 text-ivory-dim/40 hover:text-ivory-dim/70 transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        <span class="font-sans text-sm tracking-widest uppercase">Explore the code</span>
      </a>
    </div>
  </div>
</div>
