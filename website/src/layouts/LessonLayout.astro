---
import "../styles/global.css";
import "katex/dist/katex.min.css";

export interface Props {
  title: string;
  description?: string;
  subject: string;       // e.g. "Probability Theory · Python"
  lessonNumber: number;
}

const {
  title,
  description = "",
  subject,
  lessonNumber,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  </head>
  <body class="bg-navy text-ivory font-serif">

    <!-- Reading progress bar -->
    <div id="reading-progress"
         style="position:fixed;top:0;left:0;height:2px;width:0%;background:#c8a44a;z-index:9999;transition:width 80ms linear;pointer-events:none;"></div>

    <!-- Top navigation bar -->
    <nav class="sticky top-0 z-50 bg-navy/95 backdrop-blur border-b border-ivory-dim/10">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center gap-4">
        <a href="/"
           class="flex items-center gap-2 text-ivory-dim/60 hover:text-ivory-dim transition-colors group shrink-0">
          <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          <span class="font-sans text-xs tracking-widest uppercase">Lessons</span>
        </a>
        <div class="h-4 w-px bg-ivory-dim/20 shrink-0"></div>
        <span class="font-mono text-xs text-amber/60 shrink-0">Lesson {String(lessonNumber).padStart(2, '0')}</span>
        <span id="nav-section" class="font-sans text-xs text-ivory-dim/60 hidden sm:block truncate">{title}</span>
        <div class="ml-auto font-mono text-xs text-ivory-dim/30 hidden md:block shrink-0">{subject}</div>
      </div>
    </nav>

    <slot />

    <footer class="bg-navy border-t border-ivory-dim/10 py-10 px-8 text-center font-sans">
      <p class="text-ivory-dim/30 text-xs">
        <a href="/" class="hover:text-ivory-dim/60 transition-colors">&#8592; Back to all lessons</a>
      </p>
    </footer>

    <script>
      // Reading progress bar
      const bar = document.getElementById('reading-progress');
      if (bar) {
        window.addEventListener('scroll', () => {
          const doc = document.documentElement;
          const scrolled = doc.scrollTop / (doc.scrollHeight - doc.clientHeight);
          bar.style.width = Math.min(scrolled * 100, 100) + '%';
        }, { passive: true });
      }

      // Section tracking — update nav label to current h2
      const navSection = document.getElementById('nav-section');
      if (navSection) {
        const headings = Array.from(document.querySelectorAll('h2'));
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                navSection.textContent = entry.target.textContent ?? '';
              }
            }
          },
          { rootMargin: '-10% 0px -80% 0px', threshold: 0 }
        );
        headings.forEach((h) => observer.observe(h));
      }
    </script>

  </body>
</html>
